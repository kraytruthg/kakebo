<%= turbo_stream.replace "budget-entry-#{@category.id}" do %>
  <%= render "budget_entries/budget_entry_link", category: @category, year: @year, month: @month, budgeted: @entry.budgeted %>
<% end %>

<%= turbo_stream.replace "available-#{@category.id}" do %>
  <span id="available-<%= @category.id %>"
        class="font-semibold <%= @available < 0 ? 'text-red-600' : 'text-emerald-600' %>">
    <%= format_amount(@available) %>
  </span>
<% end %>

<%= turbo_stream.replace "ready-to-assign" do %>
  <p id="ready-to-assign" class="text-4xl font-bold tracking-tight">
    <%= format_amount(@ready_to_assign) %>
  </p>
<% end %>

<%= turbo_stream.replace "total-budgeted" do %>
  <p id="total-budgeted" class="text-4xl font-bold tracking-tight">
    <%= format_amount(@total_budgeted) %>
  </p>
<% end %>
