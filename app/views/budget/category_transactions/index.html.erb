<div class="px-4 py-4 lg:max-w-4xl lg:mx-auto lg:px-6 lg:py-8">
  <%# Header %>
  <div class="mb-6">
    <%= link_to budget_path(year: @year, month: @month),
          class: "inline-flex items-center gap-1 text-sm text-slate-400 hover:text-slate-700 mb-2" do %>
      <%= icon "chevron-left", classes: "w-4 h-4" %>
      預算
    <% end %>
    <h1 class="text-2xl font-bold text-slate-900">
      <%= @category.name %>
      <span class="text-slate-400 font-normal text-lg ml-2">所有紀錄</span>
    </h1>
  </div>

  <%# Account filter chips %>
  <div class="flex flex-wrap gap-2 mb-5">
    <%= link_to "全部",
          budget_category_transactions_path(@year, @month, @category),
          class: "px-3 py-1.5 rounded-full text-sm font-medium transition-colors #{@selected_account.nil? ? 'bg-indigo-600 text-white' : 'bg-slate-100 text-slate-600 hover:bg-slate-200'}" %>
    <% @accounts.each do |account| %>
      <%= link_to account.name,
            budget_category_transactions_path(@year, @month, @category, account_id: account.id),
            class: "px-3 py-1.5 rounded-full text-sm font-medium transition-colors #{@selected_account&.id == account.id ? 'bg-indigo-600 text-white' : 'bg-slate-100 text-slate-600 hover:bg-slate-200'}" %>
    <% end %>
  </div>

  <%# Mobile transaction cards %>
  <div class="lg:hidden space-y-2">
    <% if @items.empty? %>
      <div class="bg-white rounded-xl border border-slate-100 py-12 text-center text-slate-400">
        <p class="text-sm">沒有此類別的交易紀錄</p>
      </div>
    <% else %>
      <% @items.each do |item| %>
        <% if item.type == :budget %>
          <div class="bg-indigo-50/50 rounded-xl border border-indigo-100 px-4 py-3">
            <div class="flex items-center justify-between">
              <div>
                <span class="text-xs text-slate-400"><%= item.date.strftime("%m/%d") %></span>
                <span class="text-sm text-indigo-600 font-medium ml-2"><%= item.memo %></span>
              </div>
              <span class="text-sm font-medium text-indigo-600"><%= format_amount(item.amount) %></span>
            </div>
          </div>
        <% else %>
          <div class="bg-white rounded-xl border border-slate-100 px-4 py-3">
            <div class="flex items-start justify-between">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2">
                  <span class="text-xs text-slate-400"><%= item.date.strftime("%m/%d") %></span>
                  <span class="text-sm text-slate-800 truncate"><%= item.memo.presence || "─" %></span>
                </div>
                <p class="text-xs text-slate-400 mt-0.5"><%= item.account_name %></p>
              </div>
              <span class="text-sm font-semibold ml-3 <%= item.amount < 0 ? 'text-red-500' : 'text-emerald-600' %>">
                <%= format_amount(item.amount) %>
              </span>
            </div>
          </div>
        <% end %>
      <% end %>
    <% end %>
  </div>

  <%# Transaction table %>
  <div class="hidden lg:block bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">
    <table class="w-full">
      <thead>
        <tr class="border-b border-slate-100">
          <th class="text-left px-5 py-3 text-xs font-medium text-slate-400">日期</th>
          <th class="text-left px-5 py-3 text-xs font-medium text-slate-400">備註</th>
          <th class="text-left px-5 py-3 text-xs font-medium text-slate-400">帳戶</th>
          <th class="text-right px-5 py-3 text-xs font-medium text-slate-400">金額</th>
          <% unless @selected_account %>
            <th class="text-right px-5 py-3 text-xs font-medium text-slate-400">餘額</th>
          <% end %>
          <th class="px-5 py-3"></th>
        </tr>
      </thead>
      <tbody>
        <% if @items.empty? %>
          <tr>
            <td colspan="<%= @selected_account ? 5 : 6 %>" class="text-center py-16 text-slate-400">
              <p class="text-sm">沒有此類別的交易紀錄</p>
            </td>
          </tr>
        <% else %>
          <% @items.each_with_index do |item, idx| %>
            <% if item.type == :budget %>
              <tr class="border-t border-slate-50 bg-indigo-50/50">
                <td class="px-5 py-3 text-sm text-slate-500"><%= item.date.strftime("%Y/%m/%d") %></td>
                <td class="px-5 py-3 text-sm text-indigo-600 font-medium"><%= item.memo %></td>
                <td class="px-5 py-3 text-sm text-slate-400">—</td>
                <td class="px-5 py-3 text-right text-sm font-medium text-indigo-600">
                  <%= format_amount(item.amount) %>
                </td>
                <% unless @selected_account %>
                  <td class="px-5 py-3 text-right text-sm text-slate-500">
                    <%= format_amount(@running_balances[idx]) %>
                  </td>
                <% end %>
                <td class="px-5 py-3"></td>
              </tr>
            <% else %>
              <tr class="border-t border-slate-50 hover:bg-slate-50 group transition-colors"
                  id="transaction-<%= item.record.id %>">
                <td class="px-5 py-3 text-sm text-slate-500"><%= item.date.strftime("%Y/%m/%d") %></td>
                <td class="px-5 py-3 text-sm text-slate-800"><%= item.memo.presence || "─" %></td>
                <td class="px-5 py-3 text-sm text-slate-400"><%= item.account_name %></td>
                <td class="px-5 py-3 text-right text-sm font-medium <%= item.amount < 0 ? 'text-red-600' : 'text-emerald-600' %>">
                  <%= format_amount(item.amount) %>
                </td>
                <% unless @selected_account %>
                  <td class="px-5 py-3 text-right text-sm text-slate-500">
                    <%= format_amount(@running_balances[idx]) %>
                  </td>
                <% end %>
                <td class="px-5 py-3">
                  <div class="flex items-center gap-2 justify-end">
                    <%= link_to "編輯",
                          edit_account_transaction_path(item.record.account, item.record),
                          class: "opacity-0 group-hover:opacity-100 transition-opacity text-sm text-blue-500 hover:text-blue-700" %>
                    <%= button_to account_transaction_path(item.record.account, item.record),
                          method: :delete,
                          data: { turbo_confirm: "確定刪除這筆交易？" },
                          class: "opacity-0 group-hover:opacity-100 transition-opacity text-slate-300 hover:text-red-500",
                          aria: { label: "刪除交易" } do %>
                      <%= icon "trash", classes: "w-4 h-4" %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          <% end %>
        <% end %>
      </tbody>
    </table>
  </div>

  <%# Pagination %>
  <% if @pagy.pages > 1 %>
    <nav class="mt-6 flex justify-center">
      <%== @pagy.series_nav %>
    </nav>
  <% end %>
</div>
