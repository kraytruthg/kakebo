<div class="max-w-lg mx-auto px-4 sm:px-6 py-8">
  <h1 class="text-xl font-bold text-slate-900 mb-6">編輯用戶</h1>

  <%= form_with model: @user, url: admin_user_path(@user), method: :patch do |f| %>
    <% if @user.errors.any? %>
      <div class="mb-4 p-3 bg-red-50 text-red-700 rounded-lg text-sm">
        <% @user.errors.full_messages.each do |msg| %>
          <p><%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <div class="space-y-4">
      <div>
        <%= f.label :name, "姓名", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.text_field :name, class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>
      <div>
        <%= f.label :email, "Email", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.email_field :email, class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>
      <div>
        <%= f.label :household_id, "家庭", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.collection_select :household_id, @households, :id, :name,
              {},
              class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <hr class="border-slate-200">
      <p class="text-xs text-slate-400">留空表示不變更密碼</p>

      <div>
        <%= f.label :password, "新密碼", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.password_field :password, class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>
      <div>
        <%= f.label :password_confirmation, "確認新密碼", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.password_field :password_confirmation, class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <%= f.submit "更新用戶", class: "w-full bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium py-2.5 rounded-lg transition-colors cursor-pointer" %>
    </div>
  <% end %>

  <div class="mt-4">
    <%= link_to "← 返回用戶列表", admin_users_path, class: "text-sm text-slate-500 hover:text-indigo-600" %>
  </div>
</div>
